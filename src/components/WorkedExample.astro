---
import Section from './Section.astro';

interface Props {
  title?: string;
}

const { title = 'Worked example' } = Astro.props;
---

<Section title={title} navLabel="Worked example" icon="📐" id="worked-example">
  <div class="worked">
    <slot />
  </div>
</Section>

<style>
  /* Author writes an ordered list of steps inside; we style it as a stepper. */
  .worked :global(ol) {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: step;
    display: grid;
    gap: 0.75rem;
  }
  .worked :global(ol > li) {
    counter-increment: step;
    position: relative;
    padding: 0.85rem 1rem 0.85rem 3rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--bg-1);
    margin: 0;
  }
  .worked :global(ol > li)::before {
    content: counter(step);
    position: absolute;
    left: 0.8rem;
    top: 0.8rem;
    width: 1.5rem;
    height: 1.5rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
  }
</style>
