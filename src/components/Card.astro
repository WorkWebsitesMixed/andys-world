---
interface Props {
  href: string;
  eyebrow?: string;
  title: string;
  /** Small tag shown top-right, e.g. a topic or "Coming soon". */
  tag?: string;
  muted?: boolean;
  /** External link styling/behaviour. */
  external?: boolean;
}

const { href, eyebrow, title, tag, muted = false, external = false } = Astro.props;
---

<a
  class:list={['card', { muted }]}
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener' : undefined}
>
  <div class="card-top">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    {tag && <span class="tag">{tag}</span>}
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-body"><slot /></p>
  <span class="arrow" aria-hidden="true">→</span>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.25rem 1.35rem;
    color: var(--text);
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(20rem 12rem at 110% -10%, var(--accent-wash), transparent 60%);
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
  }
  .card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: var(--shadow), 0 0 0 1px var(--accent-wash), 0 10px 36px rgba(0, 0, 0, 0.5);
  }
  .card:hover::before { opacity: 1; }
  .card.muted { opacity: 0.78; }
  .card.muted:hover { opacity: 1; }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    min-height: 1rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    color: var(--text-faint);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }
  .card-title {
    font-size: 1.15rem;
  }
  .card-body {
    color: var(--text-dim);
    font-size: 0.92rem;
    margin: 0;
  }
  .arrow {
    margin-top: auto;
    align-self: flex-end;
    color: var(--accent);
    transition: transform 0.18s ease;
  }
  .card:hover .arrow { transform: translateX(4px); }
</style>
