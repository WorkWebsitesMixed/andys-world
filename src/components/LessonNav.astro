---
/**
 * Floating section navigator for lessons.
 * Auto-built on the client from every [data-section] block inside the lesson,
 * with active-section highlighting on scroll. Fixed, vertically centred,
 * translucent. Shown only on wide screens (see media query); hidden otherwise.
 */
---

<nav class="lesson-nav" data-lesson-nav aria-label="On this page" hidden>
  <p class="ln-head">On this page</p>
  <ul></ul>
</nav>

<style>
  .lesson-nav {
    position: fixed;
    left: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    width: 11rem;
    max-height: 80vh;
    overflow-y: auto;
    padding: 0.9rem 0.95rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--bg-1) 72%, transparent);
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow);
    /* hidden by default; only revealed on wide screens once populated */
    display: none;
  }

  .ln-head {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 0.6rem;
  }

  .lesson-nav :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.1rem;
  }
  .lesson-nav :global(a) {
    display: block;
    padding: 0.32rem 0.5rem;
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--text-faint);
    font-size: 0.82rem;
    line-height: 1.3;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .lesson-nav :global(a:hover) {
    color: var(--text);
    background: var(--bg-3);
  }
  .lesson-nav :global(a.active) {
    color: var(--accent);
    border-left-color: var(--accent);
    background: var(--accent-wash);
  }

  /* Only show when there is comfortable room beside the 52rem column. */
  @media (min-width: 1280px) {
    .lesson-nav.ready {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lesson-nav :global(a) { transition: none; }
  }
</style>

<script>
  // Build the navigator from the lesson's [data-section] blocks, then keep the
  // active item in sync with scroll position via IntersectionObserver.
  const root = document.querySelector<HTMLElement>('[data-lesson-root]');
  const nav = document.querySelector<HTMLElement>('[data-lesson-nav]');

  if (root && nav) {
    const list = nav.querySelector('ul');
    const sections = Array.from(
      root.querySelectorAll<HTMLElement>('[data-section][id]'),
    );

    if (!list || sections.length < 2) {
      nav.remove(); // not worth showing for a short lesson
    } else {
      const linkById = new Map<string, HTMLAnchorElement>();

      for (const sec of sections) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${sec.id}`;
        a.textContent = sec.dataset.section ?? sec.id;
        a.addEventListener('click', () => setActive(sec.id));
        li.appendChild(a);
        list.appendChild(li);
        linkById.set(sec.id, a);
      }

      function setActive(id: string) {
        linkById.forEach((a) => a.classList.remove('active'));
        linkById.get(id)?.classList.add('active');
      }

      nav.hidden = false;
      nav.classList.add('ready');

      // Highlight the section nearest the top of the viewport.
      const visible = new Set<string>();
      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            const id = (e.target as HTMLElement).id;
            if (e.isIntersecting) visible.add(id);
            else visible.delete(id);
          }
          // pick the topmost currently-visible section
          let topId: string | null = null;
          let topY = Infinity;
          for (const id of visible) {
            const el = document.getElementById(id);
            if (!el) continue;
            const y = el.getBoundingClientRect().top;
            if (y < topY) {
              topY = y;
              topId = id;
            }
          }
          if (topId) setActive(topId);
        },
        { rootMargin: '-80px 0px -70% 0px', threshold: 0 },
      );

      sections.forEach((s) => observer.observe(s));
      setActive(sections[0].id);
    }
  }
</script>
