---
import { Code } from 'astro:components';
import { url } from '../lib/url';

interface Props {
  code: string;
  filename: string;
  label: string;
}

const { code, filename, label } = Astro.props;
const downloadHref = url(`python/${filename}`);

const ext = filename.split('.').pop() ?? '';
const lang = ext === 'py' ? 'python' : ext === 'csv' ? 'csv' : 'text';
---

<div class="code-file">
  <div class="cf-header">
    <div class="cf-meta">
      <span class="cf-label">{label}</span>
      <span class="cf-filename">{filename}</span>
    </div>
    <div class="cf-actions">
      <button class="cf-copy" data-filename={filename} aria-label={`Copy ${filename}`}>
        Copy
      </button>
      <a class="cf-download" href={downloadHref} download={filename} aria-label={`Download ${filename}`}>
        Download .py
      </a>
    </div>
  </div>
  <div class="cf-code">
    <Code code={code} lang={lang} theme="github-dark" />
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.cf-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const pre = btn.closest('.code-file')?.querySelector('pre');
      if (!pre) return;
      navigator.clipboard.writeText(pre.textContent ?? '').then(() => {
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('copied');
        }, 2000);
      });
    });
  });
</script>

<style>
  .code-file {
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    overflow: hidden;
    margin-block: 1.5rem;
  }

  .cf-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: var(--bg-2);
    border-bottom: 1px solid var(--line-strong);
    flex-wrap: wrap;
  }

  .cf-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cf-label {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }

  .cf-filename {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
  }

  .cf-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-shrink: 0;
  }

  .cf-copy,
  .cf-download {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.25rem 0.7rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
    text-decoration: none;
  }

  .cf-copy {
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--line-strong);
  }
  .cf-copy:hover { background: var(--bg-3); color: var(--text); }
  .cf-copy.copied { color: var(--ok); border-color: var(--ok); }

  .cf-download {
    background: var(--accent-wash);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .cf-download:hover {
    background: color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .cf-code :global(pre) {
    margin: 0;
    border-radius: 0;
    padding: 1.1rem 1.25rem;
    font-size: 0.85rem;
    line-height: 1.6;
    overflow-x: auto;
  }

  /* Ensure selection includes only code text, not any decoration */
  .cf-code :global(pre) ::selection {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
  }
</style>
