---
/**
 * Shared base for Support and Extension — the two collapsible lesson aids.
 * Not used directly in MDX; Support and Extension are the public-facing wrappers.
 */
interface Props {
  title: string;
  icon: string;
  variant: 'support' | 'extension';
  /** Optional badge rendered after the title (e.g. "optional"). */
  flagText?: string;
}

const { title, icon, variant, flagText } = Astro.props;
---

<details class:list={['aid', `v-${variant}`]}>
  <summary>
    <span class="aid-ic" aria-hidden="true">{icon}</span>
    <span class="aid-title">{title}</span>
    {flagText && <span class="aid-flag">{flagText}</span>}
    <span class="aid-chevron" aria-hidden="true"></span>
  </summary>
  <div class="aid-body">
    <slot />
  </div>
</details>

<style>
  /* --- Shared layout -------------------------------------------------------- */
  .aid { margin-block: 1.25rem; }

  summary {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.8rem 1rem;
    cursor: pointer;
    font-family: var(--font-head);
    font-weight: 600;
    list-style: none;
  }
  summary::-webkit-details-marker { display: none; }

  .aid-title { flex: 1; }

  .aid-chevron {
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid var(--text-faint);
    border-bottom: 2px solid var(--text-faint);
    transform: rotate(-45deg);
    transition: transform 0.18s ease;
  }
  .aid[open] .aid-chevron { transform: rotate(45deg); }

  .aid-body { padding: 0 1rem 1rem; }
  .aid-body :global(p:first-child) { margin-top: 0; }
  .aid-body :global(p:last-child) { margin-bottom: 0; }

  /* --- Variant: support ----------------------------------------------------- */
  .v-support {
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent-2);
    border-radius: 0 var(--radius) var(--radius) 0;
    background: var(--accent-2-wash);
  }

  /* --- Variant: extension --------------------------------------------------- */
  .v-extension {
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius);
    background: var(--bg-1);
  }

  .aid-flag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
  }
</style>
