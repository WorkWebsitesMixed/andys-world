---
/**
 * The simple required project circuit: cell → switch → resistor → LED.
 * Theme-aware inline SVG.
 */
const caption =
  'The required circuit: a cell (battery) powers the loop, a switch turns it on and off, a resistor protects the LED, and the LED is the output.';
---

<figure class="diagram">
  <svg viewBox="0 0 360 210" role="img" aria-labelledby="cir-t cir-d" class="dg">
    <title id="cir-t">A simple switch-operated LED circuit</title>
    <desc id="cir-d">{caption}</desc>

    <!-- Wires (loop with gaps for components) -->
    <g class="wire">
      <!-- top: left run, gap for switch, right run -->
      <line x1="40" y1="50" x2="140" y2="50" />
      <line x1="180" y1="50" x2="320" y2="50" />
      <!-- right: top run, gap for resistor, bottom run -->
      <line x1="320" y1="50" x2="320" y2="92" />
      <line x1="320" y1="128" x2="320" y2="160" />
      <!-- bottom: right run, gap for LED, left run -->
      <line x1="320" y1="160" x2="210" y2="160" />
      <line x1="150" y1="160" x2="40" y2="160" />
      <!-- left: bottom run, gap for cell, top run -->
      <line x1="40" y1="160" x2="40" y2="118" />
      <line x1="40" y1="92" x2="40" y2="50" />
    </g>

    <!-- Switch (top) -->
    <circle cx="140" cy="50" r="2.5" class="node" />
    <circle cx="180" cy="50" r="2.5" class="node" />
    <line x1="140" y1="50" x2="174" y2="36" class="member" />
    <text x="160" y="28" text-anchor="middle">switch</text>

    <!-- Resistor (right) — IEC rectangle -->
    <rect x="311" y="92" width="18" height="36" class="bar" />
    <text x="300" y="114" text-anchor="end">resistor</text>

    <!-- LED (bottom) — triangle + bar + light arrows -->
    <polygon points="210,148 210,172 178,160" class="member fill-bg" />
    <line x1="178" y1="146" x2="178" y2="174" class="member" />
    <line x1="196" y1="140" x2="206" y2="128" class="arrow" marker-end="url(#cir-arrow)" />
    <line x1="184" y1="136" x2="194" y2="124" class="arrow" marker-end="url(#cir-arrow)" />
    <text x="194" y="192" text-anchor="middle">LED</text>

    <!-- Cell (left) -->
    <line x1="26" y1="104" x2="54" y2="104" class="member" />
    <line x1="34" y1="114" x2="46" y2="114" class="member thick" />
    <text x="64" y="112" text-anchor="start">cell</text>

    <defs>
      <marker id="cir-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="fill-accent" />
      </marker>
    </defs>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>

<style>
  .diagram { margin-block: 1.75rem; }
  .dg { width: 100%; height: auto; max-width: 360px; display: block; margin-inline: auto; }
  figcaption {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-faint);
    text-align: center;
    max-width: 38rem;
    margin-inline: auto;
  }
  .wire line { stroke: var(--text); stroke-width: 2; }
  .member { fill: none; stroke: var(--text); stroke-width: 2.5; stroke-linejoin: round; }
  .thick { stroke-width: 4; }
  .fill-bg { fill: var(--bg); }
  .bar { fill: var(--bg-3); stroke: var(--text); stroke-width: 2.5; }
  .node { fill: var(--text); }
  .arrow { stroke: var(--accent); stroke-width: 2; fill: none; }
  .fill-accent { fill: var(--accent); }
  text { fill: var(--text-dim); font-family: var(--font-body); font-size: 12px; }
</style>
