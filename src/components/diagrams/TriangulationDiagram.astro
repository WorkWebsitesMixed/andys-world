---
/**
 * Triangulation: a square frame racks; adding a diagonal makes it rigid.
 * Theme-aware inline SVG (recolours with the active theme).
 */
const caption =
  'A square frame racks (leans over) under a sideways push. Adding a diagonal splits it into triangles, which cannot change shape — so the frame becomes rigid.';
---

<figure class="diagram">
  <svg viewBox="0 0 420 210" role="img" aria-labelledby="tri-t tri-d" class="dg">
    <title id="tri-t">Triangulation makes a frame rigid</title>
    <desc id="tri-d">{caption}</desc>
    <defs>
      <marker id="tri-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" class="fill-danger" />
      </marker>
    </defs>

    <!-- LEFT: a racked square -->
    <polygon points="40,40 160,40 160,160 40,160" class="ghost" />
    <polygon points="70,40 190,40 160,160 40,160" class="member danger" />
    <line x1="78" y1="26" x2="128" y2="26" class="member danger" marker-end="url(#tri-arrow)" />
    <text x="115" y="195" text-anchor="middle">Square frame — racks</text>

    <!-- RIGHT: a triangulated square -->
    <polygon points="250,40 370,40 370,160 250,160" class="member" />
    <line x1="250" y1="160" x2="370" y2="40" class="member accent" />
    <text x="310" y="195" text-anchor="middle">Add a diagonal — rigid</text>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>

<style>
  .diagram { margin-block: 1.75rem; }
  .dg { width: 100%; height: auto; max-width: 460px; display: block; margin-inline: auto; }
  figcaption {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-faint);
    text-align: center;
    max-width: 38rem;
    margin-inline: auto;
  }
  .member { fill: none; stroke: var(--text); stroke-width: 3; stroke-linejoin: round; }
  .ghost { fill: none; stroke: var(--text-faint); stroke-width: 1.5; stroke-dasharray: 5 5; }
  .accent { stroke: var(--accent); stroke-width: 3.5; }
  .danger { stroke: var(--bad); }
  .fill-danger { fill: var(--bad); }
  text { fill: var(--text-dim); font-family: var(--font-body); font-size: 13px; }
</style>
