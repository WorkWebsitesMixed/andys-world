---
/**
 * Consistent section shell for lesson content blocks.
 * Renders an accent-marked heading + optional icon, then the slotted body.
 */
interface Props {
  title: string;
  icon?: string;
  id?: string;
  /** Short label for the section navigator (defaults to the title). */
  navLabel?: string;
  /** Visual accent: cyan (default) or violet for affective/SEL blocks. */
  variant?: 'cyan' | 'violet';
}

const { title, icon, id, navLabel, variant = 'cyan' } = Astro.props;

// Stable anchor id (from the title when not given) so the section navigator
// can link to every section.
const slug =
  id ??
  title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
---

<section class:list={['lesson-section', `v-${variant}`]} id={slug} data-section={navLabel ?? title}>
  <h2 class="sec-title">
    {icon && <span class="sec-icon" aria-hidden="true">{icon}</span>}
    <span>{title}</span>
  </h2>
  <div class="sec-body">
    <slot />
  </div>
</section>

<style>
  .lesson-section {
    margin-block: 2.5rem;
  }
  .sec-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.3rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 1rem;
  }
  .sec-icon {
    display: inline-grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    font-size: 1rem;
    border-radius: var(--radius-sm);
    background: var(--accent-wash);
    border: 1px solid var(--line-strong);
  }
  .v-violet .sec-icon {
    background: var(--accent-2-wash);
  }
  .sec-body :global(p) { margin-block: 0.75rem; }
  .sec-body :global(ul),
  .sec-body :global(ol) { padding-left: 1.4rem; margin-block: 0.75rem; }
  .sec-body :global(li) { margin-block: 0.35rem; }
</style>
