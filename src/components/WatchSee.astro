---
/**
 * "Watch / See" — curated external links (videos, animations, galleries) chosen
 * to introduce a concept visually. External, opens in a new tab, optional.
 * Links are hand-approved, not auto-generated.
 */
interface Item {
  label: string;
  href: string;
  /** "Video", "Animation", "Gallery", "Interactive". */
  kind?: string;
  /** Optional one-line note on what to look for. */
  note?: string;
}

interface Props {
  title?: string;
  items: Item[];
}

const { title = 'Watch & see', items } = Astro.props;

const icons: Record<string, string> = {
  Video: '🎬',
  Animation: '✨',
  Gallery: '🖼️',
  Interactive: '🕹️',
};
---

<aside class="watchsee">
  <p class="ws-head">
    <span aria-hidden="true">👁️</span>
    <span>{title}</span>
    <span class="ws-flag">external · optional</span>
  </p>
  <ul>
    {items.map((it) => (
      <li>
        <span class="ws-ic" aria-hidden="true">{(it.kind && icons[it.kind]) || '🔗'}</span>
        <span class="ws-main">
          <a href={it.href} target="_blank" rel="noopener noreferrer">
            {it.label} <span class="ext" aria-hidden="true">↗</span>
          </a>
          {it.note && <span class="ws-note">{it.note}</span>}
        </span>
        {it.kind && <span class="ws-kind">{it.kind}</span>}
      </li>
    ))}
  </ul>
</aside>

<style>
  .watchsee {
    margin-block: 1.5rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    background: var(--bg-1);
  }
  .ws-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.7rem;
    font-family: var(--font-head);
    font-weight: 600;
  }
  .ws-flag {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
  }
  .watchsee ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.55rem; }
  .watchsee li { display: flex; align-items: baseline; gap: 0.6rem; }
  .ws-ic { flex: none; }
  .ws-main { display: flex; flex-direction: column; gap: 0.1rem; }
  .ws-note { font-size: 0.82rem; color: var(--text-faint); }
  .ws-kind {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-faint);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
    white-space: nowrap;
  }
  .ext { color: var(--accent); }
</style>
