---
import { site } from '../lib/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container inner">
    <p class="who">
      <strong>{site.name}</strong> — {site.author}
      <span class="faint">· {site.role}</span>
    </p>
    <p class="faint small">© {year} {site.author}. Built with Astro.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--line);
    background: var(--bg-1);
  }
  .inner {
    padding-block: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .who { font-size: 0.95rem; }
  .small { font-size: 0.82rem; }
</style>
