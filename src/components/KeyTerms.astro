---
import Section from './Section.astro';

interface Term {
  term: string;
  definition: string;
}

interface Props {
  terms: Term[];
}

const { terms } = Astro.props;
---

<Section title="Key terms" icon="🔑" id="key-terms">
  <dl class="terms">
    {terms.map((t) => (
      <div class="row">
        <dt>{t.term}</dt>
        <dd>{t.definition}</dd>
      </div>
    ))}
  </dl>
</Section>

<style>
  .terms { display: grid; gap: 0.6rem; margin: 0; }
  .row {
    display: grid;
    grid-template-columns: minmax(7rem, 12rem) 1fr;
    gap: 0.5rem 1rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--bg-1);
  }
  dt {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 600;
  }
  dd { margin: 0; color: var(--text-dim); }
  @media (max-width: 520px) {
    .row { grid-template-columns: 1fr; gap: 0.2rem; }
  }
</style>
