---
/**
 * "Need a hand?" — collapsible scaffold for students who want extra support
 * (sentence frames, worked models, simplified steps). Collapsed by default so
 * it never clutters the lesson. Not added to the section navigator.
 */
import DisclosureBlock from './DisclosureBlock.astro';

interface Props {
  title?: string;
}

const { title = 'Need a hand?' } = Astro.props;
---

<DisclosureBlock variant="support" icon="🤝" title={title}>
  <slot />
</DisclosureBlock>
