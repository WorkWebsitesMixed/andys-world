---
/**
 * "Go deeper" — optional stretch task for students who finish early or want
 * more challenge. Clearly flagged as not required. Collapsed by default;
 * not added to the section navigator.
 */
import DisclosureBlock from './DisclosureBlock.astro';

interface Props {
  title?: string;
}

const { title = 'Go deeper' } = Astro.props;
---

<DisclosureBlock variant="extension" icon="🚀" title={title} flagText="optional">
  <slot />
</DisclosureBlock>
