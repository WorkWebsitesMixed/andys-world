---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import { COURSES } from '../lib/courses';
import { routes } from '../lib/url';

function courseTag(course: (typeof COURSES)[number]): string {
  if (course.structure === 'sprint') {
    const total = course.sprints.flatMap((s) => s.weeks).length;
    return `${total} sessions`;
  }
  return `${course.blocks.length} blocks · ${course.blocks[course.blocks.length - 1].classRange[1]} classes`;
}
---

<BaseLayout title="Extracurricular Courses">
  <section class="container head">
    <span class="eyebrow">After School</span>
    <h1>Extracurricular Courses</h1>
    <p class="muted lede">
      Courses for students who want to go further — open to any grade, running after school.
      Each course builds a real, demoable project over the year.
    </p>
  </section>

  <section class="container">
    <div class="course-grid">
      {COURSES.map((course) => (
        <Card
          href={routes.course(course.id)}
          eyebrow="After school · Mixed grades"
          title={course.name}
          tag={courseTag(course)}
        >
          {course.tagline}
        </Card>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .head { padding-block: 2.5rem 1.5rem; }
  .head h1 { margin: 0.4rem 0 0.6rem; }
  .lede { max-width: 42rem; }

  .course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1.25rem;
    padding-bottom: 3rem;
  }
</style>
