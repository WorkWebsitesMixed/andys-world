---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Card from '../../components/Card.astro';
import { COURSES, getCourse } from '../../lib/courses';
import { routes } from '../../lib/url';

export const getStaticPaths = (() => {
  return COURSES.map((c) => ({ params: { courseId: c.id } }));
}) satisfies GetStaticPaths;

const { courseId } = Astro.params;
const course = getCourse(courseId)!;
---

<BaseLayout title={course.name}>
  <section class="container head">
    <Breadcrumbs
      items={[
        { label: 'Extracurricular', href: routes.extracurricular() },
        { label: course.name },
      ]}
    />
    <span class="eyebrow">Extracurricular · After School · Mixed Grades</span>
    <h1>{course.name}</h1>
    <p class="muted lede">{course.blurb}</p>
  </section>

  <section class="container">
    <div class="sprint-grid">
      {course.sprints.map((sprint) => (
        <Card
          href={routes.sprint(courseId, sprint.id)}
          eyebrow={`Sprint ${sprint.id}`}
          title={sprint.name}
          tag={`${sprint.weeks.length} sessions`}
        >
          Weeks {sprint.weeks[0]}–{sprint.weeks[sprint.weeks.length - 1]}
        </Card>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .head { padding-block: 2.5rem 1.5rem; }
  .head h1 { margin: 0.4rem 0 0.6rem; }
  .lede { max-width: 42rem; }

  .sprint-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
    gap: 1.25rem;
    padding-bottom: 3rem;
  }
</style>
