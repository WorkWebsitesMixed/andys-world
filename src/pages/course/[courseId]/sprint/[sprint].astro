---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import Card from '../../../../components/Card.astro';
import { COURSES, getCourse, getSprint } from '../../../../lib/courses';
import { routes } from '../../../../lib/url';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async () => {
  return COURSES.flatMap((c) =>
    c.sprints.map((s) => ({
      params: { courseId: c.id, sprint: String(s.id) },
    })),
  );
}) satisfies GetStaticPaths;

const { courseId, sprint } = Astro.params;
const sprintNum = Number(sprint);
const course = getCourse(courseId)!;
const sprintInfo = getSprint(course, sprintNum)!;

const allSessions = await getCollection('sessions', (s) =>
  s.data.courseId === courseId && s.data.sprint === sprintNum && !s.data.draft,
);
const byWeek = new Map(allSessions.map((s) => [s.data.week, s]));
---

<BaseLayout title={`${course.name} · Sprint ${sprintNum}: ${sprintInfo.name}`}>
  <section class="container head">
    <Breadcrumbs
      items={[
        { label: 'Extracurricular', href: routes.extracurricular() },
        { label: course.name, href: routes.course(courseId) },
        { label: `Sprint ${sprintNum}: ${sprintInfo.name}` },
      ]}
    />
    <span class="eyebrow sprint-label" style={`--sprint-color: ${sprintInfo.color}`}>
      Sprint {sprintNum}
    </span>
    <h1>{sprintInfo.name}</h1>
    <p class="muted">
      {sprintInfo.weeks.length} sessions · Weeks {sprintInfo.weeks[0]}–{sprintInfo.weeks[sprintInfo.weeks.length - 1]}
    </p>
  </section>

  <section class="container">
    <div class="grid">
      {sprintInfo.weeks.map((w) => {
        const session = byWeek.get(w);
        const ready = Boolean(session);
        return (
          <Card
            href={routes.session(courseId, sprintNum, w)}
            eyebrow={`Week ${w}`}
            title={session?.data.title ?? `Week ${w}`}
            tag={ready ? session!.data.topic : 'Coming soon'}
            muted={!ready}
          >
            {ready ? session!.data.payoff : 'This session is being prepared.'}
          </Card>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .head { padding-block: 2.5rem 1rem; }
  .head h1 { margin: 0.4rem 0 0.4rem; }

  .sprint-label {
    color: var(--sprint-color);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15rem), 1fr));
    gap: 1rem;
    padding-bottom: 3rem;
  }
</style>
