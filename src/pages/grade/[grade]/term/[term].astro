---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import Card from '../../../../components/Card.astro';
import {
  GRADES,
  TERMS,
  getGrade,
  termLabel,
  weeksForTerm,
  defaultWeekTitle,
  getTermFocus,
  bonusWeekStart,
} from '../../../../lib/curriculum';
import { routes } from '../../../../lib/url';
import { getTermLessons } from '../../../../lib/lessons';

export const getStaticPaths = (() => {
  return GRADES.flatMap((g) =>
    TERMS.map((t) => ({ params: { grade: String(g.id), term: String(t) } })),
  );
}) satisfies GetStaticPaths;

const { grade, term } = Astro.params;
const gradeNum = Number(grade);
const termNum = Number(term);
const info = getGrade(gradeNum)!;

const lessons = await getTermLessons(gradeNum, termNum);
const byWeek = new Map(lessons.map((l) => [l.data.week, l]));
const weeks = weeksForTerm(termNum, gradeNum);
const focus = getTermFocus(gradeNum, termNum);

const bonusStart = bonusWeekStart(gradeNum, termNum);
const mainWeeks = bonusStart ? weeks.filter((w) => w < bonusStart) : weeks;
const bonusWeeks = bonusStart ? weeks.filter((w) => w >= bonusStart) : [];
---

<BaseLayout title={`${info.name} · ${termLabel(termNum)}`}>
  <section class="container head">
    <Breadcrumbs
      items={[
        { label: info.name, href: routes.grade(gradeNum) },
        { label: termLabel(termNum) },
      ]}
    />
    <span class="eyebrow">{info.name} · {focus?.title ?? info.subject}</span>
    <h1>{termLabel(termNum)}</h1>
    <p class="muted">
      {focus ? focus.blurb : 'Pick a week to open its class.'}
    </p>
  </section>

  <section class="container">
    {bonusWeeks.length > 0 && <h2 class="section-heading">Main Sessions</h2>}
    <div class="grid">
      {mainWeeks.map((w) => {
        const lesson = byWeek.get(w);
        const ready = Boolean(lesson);
        return (
          <Card
            href={routes.week(gradeNum, termNum, w)}
            eyebrow={`Week ${w}`}
            title={lesson?.data.title ?? defaultWeekTitle(termNum, w)}
            tag={ready ? lesson!.data.topic : 'Coming soon'}
            muted={!ready}
          >
            {ready ? lesson!.data.learningGoal : 'This lesson is being prepared.'}
          </Card>
        );
      })}
    </div>

    {bonusWeeks.length > 0 && (
      <>
        <h2 class="section-heading bonus-heading">Bonus Sessions</h2>
        <p class="muted bonus-blurb">45-minute sessions running in the same weeks as the main programme.</p>
        <div class="grid">
          {bonusWeeks.map((w) => {
            const lesson = byWeek.get(w);
            const ready = Boolean(lesson);
            const bonusNum = w - bonusStart! + 1;
            return (
              <Card
                href={routes.week(gradeNum, termNum, w)}
                eyebrow={`Bonus B${bonusNum}`}
                title={lesson?.data.title ?? `Bonus B${bonusNum}`}
                tag={ready ? lesson!.data.topic : 'Coming soon'}
                muted={!ready}
              >
                {ready ? lesson!.data.learningGoal : 'This lesson is being prepared.'}
              </Card>
            );
          })}
        </div>
      </>
    )}
  </section>
</BaseLayout>

<style>
  .head { padding-block: 2rem 1rem; }
  .head h1 { margin: 0.4rem 0 0.4rem; }
  .section-heading {
    font-size: 1rem;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 2rem 0 0.75rem;
  }
  .bonus-heading { margin-top: 3rem; }
  .bonus-blurb { margin: -0.25rem 0 0.75rem; font-size: 0.875rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15rem), 1fr));
    gap: 1rem;
  }
</style>
